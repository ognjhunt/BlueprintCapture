rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// CANONICAL Firestore ruleset for Firebase project `blueprint-8c1ca`.
//
// This file is the SINGLE canonical ruleset deployed to the (default) Firestore
// instance. It is a SUPERSET of what both clients need:
//   • the iOS capturer app  (BlueprintCapture)  — via the Firebase client SDK
//   • the Blueprint WebApp                       — via the Firebase client SDK
//
// It MUST be kept byte-identical in both repos:
//   • BlueprintCapture/firestore.rules
//   • Blueprint-WebApp/firestore.rules
// because `firebase deploy --only firestore:rules` is last-writer-wins for the
// whole project — whichever repo deploys, the deployed rules must still permit
// every collection each client reads/writes. See beta blocker XR-01.
//
// Admin-SDK access (Cloud Functions / server routes) BYPASSES these rules and
// needs no allow rule here. Only client-SDK (rule-governed) access is modeled.
//
// Parity is enforced by:
//   Blueprint-WebApp/scripts/check-firestore-rules-parity.sh
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // Alias kept for parity with historical WebApp rules.
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && (request.auth.token.admin == true
          || request.auth.token.role in ['admin', 'ops']
          || (request.auth.token.keys().hasAny(['roles'])
            && request.auth.token.roles.hasAny(['admin', 'ops'])));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isStringField(field) {
      return field is string;
    }

    function hasValidScenePayload(data) {
      return isStringField(data.id)
        && isStringField(data.name)
        && isStringField(data.title)
        && isStringField(data.status)
        && isStringField(data.source)
        && isStringField(data.ownerUid)
        && (!('orgId' in data) || data.orgId is string)
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isSceneOwner() {
      return isSignedIn()
        && resource.data.ownerUid == request.auth.uid;
    }

    function sceneOwnershipUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['ownerUid', 'orgId']);
    }

    function captureSubmissionClientCreateKeys() {
      return [
        'capture_id',
        'scene_id',
        'creator_id',
        'job_id',
        'capture_source',
        'status',
        'requested_outputs',
        'has_site_identity',
        'has_capture_topology',
        'created_at',
        'submitted_at',
        'capture_job_id',
        'buyer_request_id',
        'site_submission_id',
        'region_id',
        'estimated_payout_cents',
        'rights_profile',
        'target_address',
        'site_identity',
        'city_context',
        'target_context',
        'raw_prefix',
        'operational_state',
        'lifecycle',
        'upload_error'
      ];
    }

    function captureSubmissionClientUpdateKeys() {
      return [
        'created_at',
        'submitted_at',
        'status',
        'operational_state',
        'lifecycle',
        'upload_error'
      ];
    }

    function captureSubmissionClientStatuses() {
      return [
        'submitted',
        'upload_failed',
        'raw_validation_failed',
        'local_preflight_failed'
      ];
    }

    function captureSubmissionClientAssignmentStates() {
      return [
        'unassigned_or_open_capture',
        'assigned_capture_job'
      ];
    }

    function captureSubmissionClientUploadStates() {
      return [
        'uploading',
        'uploaded',
        'failed'
      ];
    }

    function captureSubmissionClientQaStates() {
      return [
        'queued',
        'not_started',
        'blocked_raw_validation',
        'blocked_local_storage',
        'blocked_local_capture_limits'
      ];
    }

    function optionalString(data, field) {
      return !(field in data) || data[field] is string;
    }

    function optionalTimestamp(data, field) {
      return !(field in data) || data[field] is timestamp;
    }

    function optionalBool(data, field) {
      return !(field in data) || data[field] is bool;
    }

    function captureSubmissionRequestStatusIsClientWritable(data) {
      return ('status' in data)
        && data.status in captureSubmissionClientStatuses();
    }

    function captureSubmissionExistingStatusAllowsClientUpdate(data) {
      return !('status' in data)
        || data.status in captureSubmissionClientStatuses();
    }

    function hasValidCaptureSubmissionOperationalState(data) {
      return !('operational_state' in data)
        || (
          data.operational_state is map
          && data.operational_state.keys().hasOnly([
            'assignment_state',
            'upload_state',
            'qa_state',
            'qa_outcome',
            'repeat_ready'
          ])
          && (!('assignment_state' in data.operational_state)
            || data.operational_state.assignment_state in captureSubmissionClientAssignmentStates())
          && (!('upload_state' in data.operational_state)
            || data.operational_state.upload_state in captureSubmissionClientUploadStates())
          && (!('qa_state' in data.operational_state)
            || data.operational_state.qa_state in captureSubmissionClientQaStates())
          && (!('qa_outcome' in data.operational_state)
            || data.operational_state.qa_outcome == null)
          && optionalBool(data.operational_state, 'repeat_ready')
        );
    }

    function hasValidCaptureSubmissionLifecycle(data) {
      return !('lifecycle' in data)
        || (
          data.lifecycle is map
          && data.lifecycle.keys().hasOnly([
            'capture_started_at',
            'upload_started_at',
            'capture_uploaded_at',
            'upload_failed_at'
          ])
          && optionalTimestamp(data.lifecycle, 'capture_started_at')
          && optionalTimestamp(data.lifecycle, 'upload_started_at')
          && optionalTimestamp(data.lifecycle, 'capture_uploaded_at')
          && optionalTimestamp(data.lifecycle, 'upload_failed_at')
        );
    }

    function hasValidCaptureSubmissionUploadError(data) {
      return !('upload_error' in data)
        || (
          data.upload_error is map
          && data.upload_error.keys().hasOnly([
            'code',
            'message',
            'recorded_at'
          ])
          && optionalString(data.upload_error, 'code')
          && optionalString(data.upload_error, 'message')
          && optionalTimestamp(data.upload_error, 'recorded_at')
        );
    }

    function hasOnlyCaptureSubmissionClientCreateKeys(data) {
      return data.keys().hasOnly(captureSubmissionClientCreateKeys());
    }

    function captureSubmissionIsClientUploaded(data) {
      return ('operational_state' in data)
        && data.operational_state is map
        && ('upload_state' in data.operational_state)
        && data.operational_state.upload_state == 'uploaded';
    }

    // Client upload transitions are monotonic: once the client has reported
    // the raw upload as fully uploaded, the record belongs to the backend.
    // The only client write still permitted is an idempotent re-assertion of
    // the uploaded/submitted terminal state (a replayed completion write) —
    // never a regression to uploading/failed or to a failure status.
    function captureSubmissionUploadTransitionIsMonotonic(existing, incoming) {
      return !captureSubmissionIsClientUploaded(existing)
        || (captureSubmissionIsClientUploaded(incoming)
          && incoming.status == 'submitted');
    }

    function hasValidClientCaptureSubmissionPayload(data) {
      return hasOnlyCaptureSubmissionClientCreateKeys(data)
        && captureSubmissionRequestStatusIsClientWritable(data)
        && hasValidCaptureSubmissionOperationalState(data)
        && hasValidCaptureSubmissionLifecycle(data)
        && hasValidCaptureSubmissionUploadError(data);
    }

    // ─── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      // Clients may update their own non-financial fields.
      // Financial fields (stats.availableBalance, stats.totalEarnings, etc.)
      // are written only by Cloud Functions via the Admin SDK, which bypasses
      // these rules entirely.
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['stats']);

      // Referral sub-collection: owner reads only; writes are server-side only.
      match /referrals/{referredUserId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }

    // ─── Referral code lookup ────────────────────────────────────────────────
    // Auth comes before the invite code step, so any authenticated user can
    // look up whether a code is valid. Unauthenticated enumeration is blocked.
    match /referralCodes/{code} {
      allow read: if isSignedIn();
      allow write: if false; // written only by server (Admin SDK)
    }

    // ─── Capture jobs (curated opportunities) ───────────────────────────────
    match /capture_jobs/{jobId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ─── WebApp server-owned control-plane records ─────────────────────────
    match /contactRequests/{id} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /inboundRequests/{requestId} {
      allow read: if isAdmin();
      allow write: if false;

      match /notes/{noteId} {
        allow read: if isAdmin();
        allow write: if false;
      }
    }

    match /leadRoutingConfig/{ruleId} {
      allow read, write: if isAdmin();
    }

    match /waitlistTokens/{id} {
      allow read, write: if false;
    }

    match /action_ledger/{id} {
      allow read, write: if false;
    }

    match /hostedSessions/{id} {
      allow read, write: if false;
    }

    match /operatingGraphEvents/{id} {
      allow read, write: if false;
    }

    match /operatingGraphState/{id} {
      allow read, write: if false;
    }

    match /buyerOutcomes/{id} {
      allow read, write: if false;
    }

    match /creatorPayouts/{id} {
      allow read, write: if false;
    }

    match /buyerOrders/{id} {
      allow read, write: if false;
    }

    match /publishedMarketplaceInventory/{id} {
      allow read, write: if false;
    }

    match /humanBlockerThreads/{id} {
      allow read, write: if false;
    }

    match /humanBlockerDispatches/{id} {
      allow read, write: if false;
    }

    match /humanReplyEvents/{id} {
      allow read, write: if false;
    }

    // ─── Scenes ──────────────────────────────────────────────────────────────
    // Client-SDK scene access is owner/admin scoped. Server routes use Admin SDK.
    // (WebApp server writes go through the Admin SDK and bypass these rules.)
    match /scenes/{id} {
      allow create: if isAuthenticated()
        && hasValidScenePayload(request.resource.data)
        && (isAdmin() || request.resource.data.ownerUid == request.auth.uid);
      allow read: if isAdmin() || isSceneOwner();
      allow update: if isAuthenticated()
        && hasValidScenePayload(request.resource.data)
        && (isAdmin() || (isSceneOwner() && sceneOwnershipUnchanged()));
      allow delete: if isAdmin() || isSceneOwner();
    }

    // ─── Capture submissions ─────────────────────────────────────────────────
    // Clients may create their own submissions and read their own.
    // Status transitions (approved, paid, etc.) and payout fields are
    // written only by backend services via the Admin SDK.
    match /capture_submissions/{captureId} {
      allow read: if isSignedIn()
        && resource.data.creator_id == request.auth.uid;
      allow create: if isOwner(request.resource.data.creator_id)
        && hasValidClientCaptureSubmissionPayload(request.resource.data);
      allow update: if isOwner(resource.data.creator_id)
        && request.resource.data.creator_id == resource.data.creator_id
        && captureSubmissionExistingStatusAllowsClientUpdate(resource.data)
        && hasValidClientCaptureSubmissionPayload(request.resource.data)
        && captureSubmissionUploadTransitionIsMonotonic(resource.data, request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(captureSubmissionClientUpdateKeys());
      allow delete: if false; // backend only
    }

    // ─── Reservations ───────────────────────────────────────────────────────
    match /reservations/{targetId} {
      allow read, write: if isOwner(resource.data.userId)
        || isOwner(request.resource.data.userId);
    }

    // ─── Target state ───────────────────────────────────────────────────────
    match /target_state/{targetId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ─── Sessions ───────────────────────────────────────────────────────────
    match /sessions/{sessionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── Session events ──────────────────────────────────────────────────────
    match /sessionEvents/{eventId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ─── Default deny ────────────────────────────────────────────────────────
    // Any collection not matched above is denied to client-SDK access.
    // Admin-SDK (Cloud Functions / server routes) bypasses this.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
